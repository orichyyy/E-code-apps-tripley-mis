{
  "name": "@web-admin-base/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "development": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run --passWithNoTests",
    "db:generate": "drizzle-kit generate --config drizzle.config.ts",
    "db:migrate": "tsx src/migrations/run-migrations.ts all",
    "db:migrate:sqlite": "tsx src/migrations/run-migrations.ts sqlite",
    "db:migrate:postgresql": "tsx src/migrations/run-migrations.ts postgresql"
  },
  "dependencies": {
    "drizzle-orm": "^0.44.2",
    "zod": "^3.25.67"
  }
}
