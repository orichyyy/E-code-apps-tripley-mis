{
  "name": "web-admin-base",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.13.1",
  "scripts": {
    "dev": "pnpm --parallel --filter @web-admin-base/api --filter @web-admin-base/web --filter @web-admin-base/worker dev",
    "dev:api": "pnpm --filter @web-admin-base/api dev",
    "dev:web": "pnpm --filter @web-admin-base/web dev",
    "dev:worker": "pnpm --filter @web-admin-base/worker dev",
    "build": "pnpm -r --sort --if-present build",
    "lint": "eslint .",
    "format": "prettier --check .",
    "verify": "pnpm format && pnpm lint && pnpm typecheck && pnpm test && pnpm db:migrate && pnpm db:migrate:postgresql && pnpm smoke:local && pnpm build",
    "typecheck": "pnpm -r --sort --if-present typecheck",
    "test": "pnpm -r --sort --if-present test",
    "test:api": "pnpm --filter @web-admin-base/api test",
    "test:web": "pnpm --filter @web-admin-base/web test",
    "smoke:local": "tsx scripts/local-smoke/index.ts",
    "seed": "pnpm --filter @web-admin-base/api seed",
    "db:generate": "pnpm --filter @web-admin-base/db db:generate",
    "db:migrate": "pnpm --filter @web-admin-base/db db:migrate",
    "db:migrate:sqlite": "pnpm --filter @web-admin-base/db db:migrate:sqlite",
    "db:migrate:postgresql": "pnpm --filter @web-admin-base/db db:migrate:postgresql"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^22.15.34",
    "@vitejs/plugin-react": "^4.6.0",
    "autoprefixer": "^10.4.21",
    "drizzle-kit": "^0.31.4",
    "eslint": "^9.30.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.2.0",
    "jsdom": "^26.1.0",
    "playwright": "^1.61.1",
    "postcss": "^8.5.6",
    "prettier": "^3.6.2",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.35.0",
    "vite": "^7.0.0",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.2.4"
  }
}
