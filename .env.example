NODE_ENV=development
API_PORT=3000
JWT_SECRET=development-only-change-me
JWT_ISSUER=web-admin-base
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_DAYS=30
